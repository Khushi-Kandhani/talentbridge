generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum UserRole {
  ADMIN
  RECRUITER
  HIRING_MANAGER
  CANDIDATE
}

enum JobStatus {
  DRAFT
  PUBLISHED
  CLOSED
  ARCHIVED
}

enum PipelineStage {
  APPLIED
  SCREENED
  SHORTLISTED
  INTERVIEW_SCHEDULED
  OFFER
  HIRED
  REJECTED
}

enum OfferCandidateResponse {
  ACCEPTED
  REJECTED
  NEGOTIATED
}

enum InterviewStatus {
  PENDING
  CONFIRMED
  CANCELLED
}

model User {
  id           String   @id @default(cuid())
  email        String   @unique
  passwordHash String
  role         UserRole
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  jobsPosted        JobPosting[] @relation("RecruiterJobs")
  applications      Application[] @relation("CandidateApplications")
  interviewsAsRecruiter Interview[] @relation("RecruiterInterviews")
  interviewsAsManager Interview[] @relation("ManagerInterviews")
  offersManaged      Offer[]      @relation("ManagerOffers")
}

model JobPosting {
  id                    String      @id @default(cuid())
  title                 String
  department            String
  type                  String
  salaryBand            String?
  requiredSkills        Json
  responsibilities      String?
  cultureNotes          String?
  status                JobStatus   @default(DRAFT)
  recruiterId           String
  totalApplications     Int         @default(0)
  screeningStageCounts  Json        @default("{}")
  daysOpen              Int         @default(0)
  createdAt             DateTime    @default(now())
  updatedAt             DateTime    @updatedAt

  recruiter User @relation("RecruiterJobs", fields: [recruiterId], references: [id])
  applications Application[]
}

model Application {
  id                  String         @id @default(cuid())
  jobId               String
  candidateId         String
  coverLetter         String?
  yearsOfExperience   Int?
  salaryExpectation   String?
  availabilityDate    DateTime?
  cvText              String?
  aiScore             Int?
  aiStrengths         Json          @default("[]")
  aiGaps              Json          @default("[]")
  stage               PipelineStage @default(APPLIED)
  createdAt           DateTime      @default(now())
  updatedAt           DateTime      @updatedAt

  job      JobPosting @relation(fields: [jobId], references: [id])
  candidate User @relation("CandidateApplications", fields: [candidateId], references: [id])
  interview Interview?
  offer Offer?
}

model Interview {
  id               String         @id @default(cuid())
  applicationId    String         @unique
  recruiterId      String
  managerId        String
  proposedSlots    Json           @default("[]")
  confirmedSlot    String?
  status           InterviewStatus @default(PENDING)
  aiQuestions      Json           @default("[]")
  createdAt        DateTime       @default(now())
  updatedAt        DateTime       @updatedAt

  application Application @relation(fields: [applicationId], references: [id])
  recruiter User @relation("RecruiterInterviews", fields: [recruiterId], references: [id])
  manager User @relation("ManagerInterviews", fields: [managerId], references: [id])
}

model Offer {
  id                     String                  @id @default(cuid())
  applicationId          String                  @unique
  managerId              String
  roleTitle              String
  salary                 String?
  startDate              DateTime?
  probationPeriod        String?
  benefits               String?
  candidateResponse      OfferCandidateResponse?
  counterText            String?
  isApprovedByRecruiter  Boolean                 @default(false)
  createdAt              DateTime                @default(now())
  updatedAt              DateTime                @updatedAt

  application Application @relation(fields: [applicationId], references: [id])
  manager User @relation("ManagerOffers", fields: [managerId], references: [id])
}
