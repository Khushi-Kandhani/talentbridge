{
  "name": "talentbridge-backend",
  "version": "1.0.0",
  "description": "TalentBridge NestJS backend",
  "private": true,
  "license": "MIT",
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "start": "node dist/main",
    "start:dev": "node -r ts-node/register src/main.ts",
    "start:prod": "node dist/main",
    "test": "jest",
    "test:e2e": "jest --config ./test/jest-e2e.json",
    "prisma:generate": "prisma generate",
    "prisma:migrate": "prisma migrate dev",
    "prisma:deploy": "prisma migrate deploy"
  },
  "dependencies": {
    "@nestjs/common": "^10.4.0",
    "@nestjs/config": "^3.0.0",
    "@nestjs/core": "^10.4.0",
    "@nestjs/platform-express": "^10.4.0",
    "@nestjs/platform-socket.io": "^11.1.28",
    "@nestjs/swagger": "^7.0.0",
    "@nestjs/websockets": "^10.4.0",
    "@prisma/client": "^5.4.0",
    "class-transformer": "^0.5.0",
    "class-validator": "^0.14.0",
    "nestjs-pino": "^4.0.0",
    "pino-http": "^9.0.0",
    "prisma": "^5.4.0",
    "reflect-metadata": "^0.2.0",
    "rxjs": "^7.0.0",
    "socket.io": "^4.0.0"
  },
  "devDependencies": {
    "@nestjs/cli": "^10.4.0",
    "@nestjs/testing": "^10.4.0",
    "@types/express": "^4.0.0",
    "@types/jest": "^29.0.0",
    "@types/node": "^20.0.0",
    "@types/supertest": "^6.0.0",
    "jest": "^29.0.0",
    "supertest": "^6.0.0",
    "ts-jest": "^29.0.0",
    "ts-node": "^10.0.0",
    "typescript": "^5.6.0"
  }
}
