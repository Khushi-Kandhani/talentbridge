# --- Database ---
DATABASE_URL=postgresql://talentbridge:talentbridge@db:5432/talentbridge?schema=public
POSTGRES_USER=talentbridge
POSTGRES_PASSWORD=talentbridge
POSTGRES_DB=talentbridge

# --- Auth ---
JWT_SECRET=replace-with-a-long-random-secret
JWT_EXPIRES_IN=15m
JWT_REFRESH_SECRET=replace-with-a-different-long-random-secret
JWT_REFRESH_EXPIRES_IN=7d

# --- AI / LLM API (Gemini, never exposed to the frontend) ---
GEMINI_API_KEY=replace-with-your-key
GEMINI_MODEL=gemini-2.0-flash

# --- App ---
PORT=3000
FRONTEND_URL=http://localhost:5173
