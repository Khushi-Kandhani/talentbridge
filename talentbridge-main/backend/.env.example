DATABASE_URL="postgresql://talentbridge:talentbridge@db:5432/talentbridge?schema=public"
PORT=3000
NODE_ENV=development

# --- Auth ---
JWT_SECRET=changeme
JWT_EXPIRES_IN=15m
JWT_REFRESH_SECRET=changeme-refresh
JWT_REFRESH_EXPIRES_IN=7d

# --- AI / LLM API (Gemini). Never exposed to the frontend — only read on the backend. ---
# If unset, AI features gracefully fall back to templates / manual review / a generic question bank.
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.0-flash
